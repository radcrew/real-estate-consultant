# Copy to .env and adjust as needed.
APP_NAME=Real Estate Consultant API

# Reserved for future dev-only toggles (``DEBUG`` still accepted as an alias). OpenAPI ``/docs`` is always on.
IS_DEV_MODE=false

DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Same as the Supabase anon (public) key — required for POST /account/password to verify the current password.
SUPABASE_ANON_KEY=

# If true, Supabase creates the user with a confirmed email (can sign in immediately).
SIGNUP_EMAIL_CONFIRM=true

# Browser origin for clients when the frontend calls this API directly (different host/port than the API).
FRONTEND_ORIGIN=http://localhost:3000

#HuggingFace
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_TOKEN=
