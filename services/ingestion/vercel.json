{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{dataset/**,**/*.pyc,__pycache__/**,.venv/**}"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/v1/jobs/process",
      "schedule": "*/15 * * * *"
    }
  ]
}
