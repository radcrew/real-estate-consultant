SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Path to the raw listing JSON file (loopnet-seed connector).
# For local dev, point at the backend dataset:
# DATASET_PATH=../../backend/dataset/raw-data.json
DATASET_PATH=dataset/raw-data.json

LOG_LEVEL=INFO

# Shared secret for the GitHub Actions job poller (.github/workflows/ingestion-cron.yml),
# sent as Authorization: Bearer <CRON_SECRET> every 15 minutes.
# Set this to the same value as the INGESTION_CRON_TOKEN GitHub secret.
CRON_SECRET=

# Shared secret the backend sends as Authorization: Bearer <SERVICE_AUTH_TOKEN>
# when calling POST /api/v1/ingest and POST /api/v1/jobs/process directly.
# Must match the backend's INGESTION_SERVICE_TOKEN.
SERVICE_AUTH_TOKEN=
# During rotation, set the new token here, deploy both services, then promote
# this value to SERVICE_AUTH_TOKEN and clear this var. See app/core/auth.py.
SERVICE_AUTH_TOKEN_NEXT=

# Outbound rate limiting for HTTP-fetching connectors ("polite ingestion").
# See app/connectors/rate_limit.py.
CONNECTOR_MAX_CONCURRENCY=2
CONNECTOR_RATE_PER_SECOND=1.0
