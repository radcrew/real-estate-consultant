SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Path to the raw listing JSON file (loopnet-seed connector).
# For local dev, point at the backend dataset:
# DATASET_PATH=../../backend/dataset/raw-data.json
DATASET_PATH=dataset/raw-data.json

LOG_LEVEL=INFO

# Vercel sets Authorization: Bearer <CRON_SECRET> on cron requests.
# Set this to the same value as your Vercel project's CRON_SECRET env var.
# Leave empty to skip auth on /api/v1/jobs/process (dev only).
CRON_SECRET=
